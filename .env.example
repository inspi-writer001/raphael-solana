# ============================================================
# Agentic Wallet — Environment Variables
# Copy this to .env and fill in the values
# Run: pnpm setup   to generate MASTER_ENCRYPTED + MASTER_SALT
# ============================================================

# === Master Key (two-layer encryption) ===
# These three work together — generate with: pnpm setup
MASTER_ENCRYPTION_PASSWORD_CRYPTO=your-strong-password-here
MASTER_ENCRYPTED=<base64-from-pnpm-setup>
MASTER_SALT=<base64-from-pnpm-setup>

# === Solana Network ===
SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# === Wallet Store ===
# Where encrypted wallet records are stored (JSON file)
# WALLET_STORE_PATH=/home/you/.solana-agent-wallets.json

# === pump.fun (no API key needed — public WebSocket) ===
# PUMPPORTAL_WS=wss://pumpportal.fun/api/data

# === X / Twitter API (developer.x.com → Projects & Apps → Keys and Tokens) ===
# Requires at minimum Basic tier ($100/mo) for read access; Free tier is write-only.
#
# OAuth 1.0a — required for posting tweets, replies, media, likes
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
#
# OAuth 2.0 App-Only Bearer Token — for efficient searches and timeline reads
X_BEARER_TOKEN=
